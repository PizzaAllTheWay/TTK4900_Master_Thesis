{
    "editor.wordWrap": "on",
    "[latex]": {
        "editor.wordWrap": "on"
    },
    "editor.wordWrapColumn": 100, // used if you choose "wordWrapColumn"/"bounded"
    //"editor.rulers": [100],  // optional guideline
    
    "cSpell.words": [
        "behaviour",
        "datastructure",
        "exteroceptive",
        "Jacobians",
        "linearities",
        "linearizes",
        "Posteriori",
        "preintegrated",
        "Preintegration"
    ],

    "latex-workshop.latex.tools": [
    {
        "name": "buildscript",
        "command": "./build.sh",
        "args": []
    }
    ],
    "latex-workshop.latex.recipes": [
    {
        "name": "buildscript",
        "tools": ["buildscript"]
    }
    ],
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.latex.recipe.default": "buildscript",
    "sarif-viewer.connectToGithubCodeScanning": "off"
}